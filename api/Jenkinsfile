pipeline {
    agent {
        docker {
            image 'node:20-alpine'  // image officielle Node 20
            args '-u root:root'     // pour éviter des soucis de droits dans le workspace
        }
    }

    options {
        timestamps()
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Install dependencies') {
            steps {
                dir('api') {
                    sh 'npm ci'
                }
            }
        }

        stage('Tests') {
            steps {
                dir('api') {
                    sh 'npm test'
                }
            }
        }
    }

    post {
        success {
            echo "Build #${env.BUILD_NUMBER} OK"
        }
        failure {
            echo "Build #${env.BUILD_NUMBER} FAILED"
        }
    }
}